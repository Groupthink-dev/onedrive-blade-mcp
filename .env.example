# Azure AD App Registration (required)
ONEDRIVE_TENANT_ID=your-tenant-id
ONEDRIVE_CLIENT_ID=your-client-id

# Client secret (optional — required for client_credentials flow)
ONEDRIVE_CLIENT_SECRET=

# Auth mode: "device_code" (interactive) or "client_credentials" (headless/CI)
ONEDRIVE_AUTH_MODE=device_code

# Write protection (default: false)
# Set to "true" to enable upload, move, delete, share operations
ONEDRIVE_WRITE_ENABLED=false

# Token cache directory (default: ~/.onedrive-blade-mcp/)
ONEDRIVE_TOKEN_CACHE_DIR=

# Transport (default: stdio)
ONEDRIVE_MCP_TRANSPORT=stdio
ONEDRIVE_MCP_HOST=127.0.0.1
ONEDRIVE_MCP_PORT=8771

# Bearer token for HTTP transport auth (disabled if empty)
ONEDRIVE_MCP_API_TOKEN=
